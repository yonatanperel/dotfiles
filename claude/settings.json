{
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "env": {},
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook notification",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook running",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/tokenshift/tmp/tokenshift hook post-tool",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook running",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook running",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/tokenshift/tmp/tokenshift hook rewrite-bash",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook exit",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook session_start",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook stop",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook subagent-start",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook subagent-stop",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook prompt_submit",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook worktree-create",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "command": "/Users/yonatan.perel/Code/bmux/target/release/bmux hook worktree-remove",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Read(./.memory/**)",
      "Edit(./.memory/**)",
      "Write(./.memory/**)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "statusLine": {
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "type": "command"
  }
}
